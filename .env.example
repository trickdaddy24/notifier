# Notifier Configuration
# Copy this file to .env and fill in your values

# Web UI password (required for the web interface)
NOTIFIER_WEB_PASSWORD=change-this-to-a-strong-password

# Timezone used for scheduling calculations
TIMEZONE=America/New_York

# Database path (Docker default)
# NOTIFIER_DB_PATH=/app/data/notifications.db

# Set to 1 to automatically seed demo reminders on first container start (useful for testing)
# SEED_SAMPLE_DATA=0
